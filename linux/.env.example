# MongoDB connection
MONGODB_URI=
DATABASE_NAME=news_portal

# HTTP server
PORT=8080
SITE_URL=http://localhost:8080

# Site identity
SITE_NAME_SHORT=DDO News
SITE_NAME_LONG=DDO News Portal

# Admin credentials (REQUIRED)
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=

# API authentication (REQUIRED)
API_KEY=

# Appearance
ICON_PACK=itlife
PRIMARY_COLOR=#0d6efd

# MongoDB collection names (defaults shown)
CATEGORIES_COLLECTION=categories
AUTHORS_COLLECTION=authors
BANNERS_COLLECTION=banners
PAGEVIEWS_COLLECTION=pageviews

# Social links (optional)
SOCIAL_FACEBOOK=
SOCIAL_TWITTER=
SOCIAL_INSTAGRAM=
SOCIAL_LINKEDIN=
SOCIAL_YOUTUBE=

# Share buttons (comma-separated: facebook,twitter,copy,whatsapp,linkedin)
SHARE_BUTTONS=

# IndexNow / Bing (optional, leave empty to disable)
INDEXNOW_KEY=

# S3-compatible image storage (optional — QNAP MyQNAPcloud, MinIO, AWS S3, Cloudflare R2)
# If all four values are set, the Media Library upload form is available in the admin panel.
# The bucket images/* objects will be automatically set to public read on startup.
#S3_ENDPOINT=https://s3.eu-central-2.myqnapcloud.io
#S3_ACCESS_KEY=
#S3_SECRET_KEY=
#S3_BUCKET=
#MEDIA_COLLECTION=media
